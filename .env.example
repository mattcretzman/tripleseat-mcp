# TripleSeat API Credentials (OAuth 2.0)
# Get these from TripleSeat: Settings > API/Webhooks > OAuth 2.0 Client Applications
TRIPLESEAT_CLIENT_ID=
TRIPLESEAT_CLIENT_SECRET=
TRIPLESEAT_REFRESH_TOKEN=

# Supabase (for API key management + usage tracking)
# Get these from Supabase: Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Admin Dashboard Password
ADMIN_PASSWORD=

# Server port (local dev only — Vercel ignores this)
PORT=3000
